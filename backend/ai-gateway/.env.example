# ============================================================
# MiniMax AI Configuration (ai-gateway)
# ============================================================
# Get your credentials: https://platform.minimax.chat
#   API Keys -> Create Key
#
# IMPORTANT: MiniMax API keys are JWT tokens (eyJ... format)
# DO NOT use legacy sk-cp-... format keys — they are expired
# ============================================================

# Required: Your MiniMax API Key (JWT format: eyJ...)
MINIMAX_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Required: Your MiniMax Group ID
# Found at: platform.minimax.chat -> API Keys page
MINIMAX_GROUP_ID=your_group_id_here

# AI Provider
# Options: mock (no cost), minimax (real AI)
AI_PROVIDER=minimax

# Model: MiniMax-M2.7 (supports 128K context)
MINIMAX_MODEL=MiniMax-M2.7
